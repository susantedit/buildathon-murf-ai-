# ========================================
# VORTEX VOICE AI - SERVER CONFIGURATION
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=5000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB Atlas connection string
# Get it from: https://cloud.mongodb.com/
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/vortex_voice_ai

# ========================================
# AI SERVICES - GROQ (FREE & FAST!)
# ========================================
# Get your FREE API key from: https://console.groq.com/
# Used for: Script generation, advice, topic explanations, planning
# Model: Llama 3.1 70B (completely free!)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=optional_backup_groq_key_here
GROQ_API_KEY_3=optional_backup_groq_key_here
GROQ_API_KEYS=optional_comma_separated_list_of_backup_keys

# ========================================
# TEXT-TO-SPEECH - MURF FALCON
# ========================================
# Get your API key from: https://murf.ai/api
# Used for: Converting AI-generated text to natural voice audio
MURF_API_KEY=your_murf_api_key_here

# ========================================
# OPTIONAL: CORS CONFIGURATION
# ========================================
# Frontend URL (for production deployment)
# FRONTEND_URL=https://your-frontend-domain.com

# ========================================
# EMAIL ALERTS (NODEMAILER + GMAIL)
# ========================================
# Gmail address to send alerts FROM
GMAIL_USER=your_gmail@gmail.com
# Gmail App Password (NOT your regular password)
# Get it: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=your_16_char_app_password

# ========================================
# OPTIONAL: NODE ENVIRONMENT
# ========================================
# NODE_ENV=development

# ========================================
# SPEECH-TO-TEXT (OPTIONAL)
# ========================================
# STT provider to use for server-side transcription of uploaded audio.
# Supported: OPENAI (Whisper). If not set, the server will return 501 for /api/transcribe.
STT_PROVIDER=OPENAI

# OpenAI API key (if using OPENAI STT)
# Get it from: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here
